  <h1>🧪 Virtual Chemistry Lab</h1>
  <p>Group Members – CS25060, CS25036, CS25059</p>

  <div class="shelf">
  <div class="chemical c1" draggable="true">HCl (Acid)</div>
    <div class="chemical c2" draggable="true">NaOH (Base)</div>
    <div class="chemical c3" draggable="true">H₂O (Water)</div>
    <div class="chemical c4" draggable="true">H₂O₂ (Peroxide)</div>
